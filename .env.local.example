# --- Supabase (shared 6x7 project; client scoped to the `translator` schema) ---
NEXT_PUBLIC_SUPABASE_URL=https://fmrnqepyyjucnfbrqawl.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<sb_publishable_anon_key>
# Server-only, bypasses RLS. Required for file/image upload + usage metering.
SUPABASE_SERVICE_ROLE_KEY=<sb_service_role_key>

# --- Speech-to-text (live fallback for iOS/Safari + all file translation) ---
GROQ_API_KEY=<your_groq_key>
GROQ_STT_MODEL=whisper-large-v3-turbo

# --- Translation brain (at least one recommended; else free MT is used) ---
OPENROUTER_API_KEY=<your_openrouter_key>
OPENROUTER_MODEL=google/gemini-2.5-flash
# Optional OpenAI fallback
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Free machine-translation fallback (optional, zero-cost) ---
# If unset, MyMemory's public API is used. Set to a LibreTranslate instance to prefer it.
LIBRETRANSLATE_URL=
